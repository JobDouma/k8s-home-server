{
    "groups": {"group:admin": ["jobdouma@gmail.com"]},

    "tagOwners": {
        "tag:k8s-operator": [],
        "tag:k8s-readers":  [],
        "tag:k8s":          ["tag:k8s-operator"],
    },

    "autoApprovers": {
        "routes": {
            "192.168.2.0/24": ["tag:k8s"],
            "10.244.0.0/16":  ["tag:k8s"],
        },
    },

    "grants": [
        {
            "src": ["tag:k8s-readers"],
            "dst": ["tag:k8s-operator"],
            "ip":  ["tcp:443"],
        },
        {
            "src": ["group:admin"],
            "dst": ["tag:k8s-operator"],
            "app": {
                "tailscale.com/cap/kubernetes": [{"impersonate": {"groups": ["system:masters"]}}],
            },
        },
    ],

    "ssh": [
        {
            "action": "check",
            "src":    ["autogroup:member"],
            "dst":    ["autogroup:self"],
            "users":  ["autogroup:nonroot", "root"],
        },
    ],

    "acls": [
        {
            "action": "accept",
            "src":    ["tag:k8s-operator"],
            "dst":    ["tag:k8s-operator:6443"],
        },
        // Allow group:admin to reach subnet router device
        {
            "action": "accept",
            "src":    ["group:admin"],
            "dst":    ["tag:k8s:*", "tag:k8s-operator:*"],
        },
        // Allow group:admin to reach LAN and pod CIDR via subnet router
        {
            "action": "accept",
            "src":    ["group:admin"],
            "dst":    ["192.168.2.0/24:*", "10.244.0.0/16:*"],
        },
    ],
}