# Local dev tools metadata
cluster-context.txt

# Absolute blocking patterns for raw secrets
**/*.key
**/*.txt
!**/.config/sops/age/keys.txt

# Sensitive cluster files - never commit raw formats
**/*.db
*kubeconfig*
*talosconfig*
*machineconfig*
homelab-ca.crt

# Explicitly whitelist safely encrypted configurations
!*.sops.yaml
!**/*.sops.yaml